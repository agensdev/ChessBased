{
  "name": "chessbased",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:openings": "npx tsx scripts/build-openings.ts",
    "test:report-transpositions": "mkdir -p .tmp && ./node_modules/.bin/esbuild scripts/test-report-transpositions.ts --bundle --platform=node --format=esm --outfile=.tmp/test-report-transpositions.mjs && node .tmp/test-report-transpositions.mjs"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@lichess-org/chessground": "^10.0.1",
    "chessops": "^0.15.0",
    "cytoscape": "^3.33.1",
    "d3-hierarchy": "^3.1.2",
    "stockfish": "^17.1.0"
  }
}
